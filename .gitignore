# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test
*.out

# Output of the go coverage tool
*.cover

# Go workspace
go.work
go.work.sum

# Dependency directories
# 注：vendor/ 已随 B1 修复提交（go mod vendor，离线优先 + 消除本地绝对路径 replace）；
# 故此处不再忽略 vendor/，让 CI 用 -mod=vendor 离线构建。若改回模块代理拉取，可重新忽略。

# Editor and IDE
.idea/
.vscode/
*.swp

# OS files
.DS_Store
Thumbs.db

# Local environment
.env
.env.*

# Local build output (repo-root build/ is SOURCE and must stay tracked)
/dist/
/bin/
/out/

# Log files
*.log

# WorkBuddy agent memory (not project source)
.workbuddy/

# POC spike binaries (keep spike source tracked, drop 105M of screenshots)
poc/**/*.png
poc/**/*.bmp
poc/**/*.raw
poc/**/*.jpg
poc/**/*.jpeg
poc/**/*.exe
